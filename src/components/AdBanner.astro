---
interface Props {
  size?: 'leaderboard' | 'rectangle' | 'sidebar';
  id?: string;
}
const { size = 'leaderboard', id = 'ad-placeholder' } = Astro.props;

const dims: Record<string, string> = {
  leaderboard: '728x90',
  rectangle:   '336x280',
  sidebar:     '300x600',
};
---

<div class={`ad-banner ad-${size}`} id={id} aria-label="Advertisement">
  <span>Advertisement · {dims[size]}</span>
</div>

<!-- Replace the div above with your actual AdSense/ad network code -->

<style>
.ad-leaderboard  { width: 100%; height: 90px; }
.ad-rectangle    { width: 100%; max-width: 336px; height: 280px; }
.ad-sidebar      { width: 100%; height: 600px; }
</style>
